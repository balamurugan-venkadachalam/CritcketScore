<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── LOCAL: coloured human-readable console output ──────────────────── -->
    <springProfile name="local">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <!-- highlight() colours by level; %cyan/%yellow for thread/logger -->
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%thread)] %yellow(%logger{40}) - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── DEV / PROD: JSON output for CloudWatch / ELK ingestion ──────────── -->
    <springProfile name="dev,prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">

                <!-- Service metadata injected as fixed JSON fields -->
                <customFields>{"service":"t20-score-consumer","team":"platform"}</customFields>

                <!-- Include MDC fields: traceId, spanId, matchId, eventId, etc. -->
                <includeMdc>true</includeMdc>

                <!-- Structured providers: MDC → context → level → logger → message → stack trace -->
                <providers>
                    <mdc/>
                    <context/>
                    <logLevel/>
                    <loggerName/>
                    <message/>
                    <stackTrace>
                        <!-- Shorten stack traces: max 10 frames per cause, shorten class names -->
                        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                            <maxDepthPerCause>10</maxDepthPerCause>
                            <shortenedClassNameLength>20</shortenedClassNameLength>
                            <exclude>^sun\.reflect\..*\.invoke</exclude>
                            <exclude>^java\.lang\.reflect\.Method\.invoke</exclude>
                        </throwableConverter>
                    </stackTrace>
                    <arguments/>
                    <tags/>
                </providers>

                <!-- Rename fields to CloudWatch / Elastic-friendly names -->
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <version>[ignore]</version>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>

            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>

        <!-- Suppress noisy framework internals in prod logs -->
        <logger name="org.apache.kafka"               level="WARN"/>
        <logger name="software.amazon.awssdk"         level="WARN"/>
        <logger name="io.netty"                       level="WARN"/>
        <logger name="com.crickscore.consumer"        level="INFO"/>
    </springProfile>

</configuration>
